{
  "builds": [
    {
      "src": "src/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/src/(.*)",
      "dest": "src/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/"
    }
  ]
}